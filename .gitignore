.pytype/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.cache/

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db

# Local Claude Code settings (per-user; a shared .claude/settings.json may be committed)
.claude/settings.local.json
